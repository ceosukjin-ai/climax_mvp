# ===== ClimaX Backend Environment =====
# 이 파일을 .env로 복사하고 실제 값 채우기
# cp .env.example .env

# --- App ---
APP_ENV=development                      # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Database (PostgreSQL + PostGIS) ---
# 로컬 개발: docker-compose up -d 로 바로 시작
# NCP 프로덕션: NCP Cloud DB for PostgreSQL endpoint
DATABASE_URL=postgresql+asyncpg://climax:climax@localhost:5432/climax
DATABASE_ECHO=false

# --- Redis Cache ---
# 로컬: localhost:6379
# NCP 프로덕션: NCP Cloud DB for Redis endpoint
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_PANO=0                   # 0 = 영구 (공간 데이터는 안 변함)
REDIS_CACHE_TTL_WEATHER=600              # 10분 (기상은 자주 바뀜)

# --- Google Street View Static API ---
# https://developers.google.com/maps/documentation/streetview
GOOGLE_STREETVIEW_API_KEY=your_google_api_key_here
GOOGLE_STREETVIEW_SIGNING_SECRET=        # 선택사항 (보안 강화)

# --- NCP Maps (Static Map only) ---
# https://www.ncloud.com/product/applicationService/maps
NCP_MAPS_CLIENT_ID=your_ncp_client_id
NCP_MAPS_CLIENT_SECRET=your_ncp_client_secret

# --- 기상청 OpenAPI ---
# https://apihub.kma.go.kr/
KMA_API_KEY=your_kma_api_key_here
KMA_BASE_URL=https://apihub.kma.go.kr/api/typ02

# --- NCP Object Storage (세그멘테이션 마스크 저장) ---
NCP_OBJECT_ACCESS_KEY=
NCP_OBJECT_SECRET_KEY=
NCP_OBJECT_BUCKET=climax-mvp
NCP_OBJECT_REGION=kr-standard

# --- ML Model ---
# ADE20K pretrained SegFormer (HuggingFace)
# 파인튜닝된 가중치가 있으면 경로 지정
SEGFORMER_MODEL_NAME=nvidia/segformer-b0-finetuned-ade-512-512
SEGFORMER_CHECKPOINT_PATH=               # 비워두면 HuggingFace에서 다운로드
SEGFORMER_DEVICE=auto                    # auto | cpu | cuda

# --- VSI Weights (논문 기본값) ---
# 지역별로 조정 가능. 논문 검증값은 (0.5, 0.3, 0.2)
VSI_WEIGHT_SVF=0.5
VSI_WEIGHT_GVI=0.3
VSI_WEIGHT_BVI=0.2

# --- CORS (프론트엔드 도메인 허용) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:19006
