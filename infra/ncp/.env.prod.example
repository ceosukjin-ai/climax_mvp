# ===== ClimaX 프로덕션 환경변수 =====
# 사용법:
#   cd infra/ncp
#   cp .env.prod.example .env.prod
#   vim .env.prod          # 아래 값 채우기
#   bash deploy.sh
#
# .env.prod는 절대 git에 커밋하지 마세요 (.gitignore에 포함되어 있는지 확인).

# --- DB 비밀번호 (필수) ---
# 아무 값이나 되지만 추측하기 어려운 값으로. 생성 예시:
#   openssl rand -base64 24
POSTGRES_PASSWORD=

# --- Google Street View Static API (필수) ---
# 로컬 backend/.env 에 있는 값을 그대로 복사하면 됩니다.
# https://developers.google.com/maps/documentation/streetview
GOOGLE_STREETVIEW_API_KEY=
GOOGLE_STREETVIEW_SIGNING_SECRET=

# --- 기상청 OpenAPI (필수) ---
# 로컬 backend/.env 에 있는 값을 그대로 복사.
# https://apihub.kma.go.kr/
KMA_API_KEY=

# --- NCP Maps (선택 — 비어 있으면 관련 기능만 동작 안 함) ---
# https://www.ncloud.com/product/applicationService/maps
NCP_MAPS_CLIENT_ID=
NCP_MAPS_CLIENT_SECRET=

# --- NCP Object Storage (선택 — 세그멘테이션 마스크 저장) ---
NCP_OBJECT_ACCESS_KEY=
NCP_OBJECT_SECRET_KEY=
NCP_OBJECT_BUCKET=climax-mvp

# --- ML 모델 (기본값 그대로 두면 됨) ---
SEGFORMER_MODEL_NAME=nvidia/segformer-b0-finetuned-ade-512-512
SEGFORMER_DEVICE=cpu

# --- CORS ---
# 웹 대시보드가 붙을 주소. 서버 IP로 직접 테스트할 거면 아래처럼.
CORS_ORIGINS=http://localhost:3000,http://180.210.77.87:8000

# --- 이미지 태그 (기본값 그대로) ---
CLIMAX_IMAGE=climax-backend:latest
